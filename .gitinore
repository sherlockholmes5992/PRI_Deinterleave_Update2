# =========================================================
# MATLAB / Simulink .gitignore
# =========================================================

# ----------------------------------------------------------------------
# MATLAB autosave & backup files
# ----------------------------------------------------------------------
*.asv
*.m~
*.autosave

# ----------------------------------------------------------------------
# Simulink cache & generated files
# ----------------------------------------------------------------------
slprj/
sfprj/
work/
cache/
codegen/
resources/project/

# Simulink cache files
*.slxc

# Generated code folders
*_ert_rtw/
*_grt_rtw/
*_rtw/

# Coverage & profiling
*.cvt
*.prof

# HTML reports
html/

# ----------------------------------------------------------------------
# Operating System files
# ----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------
# Visual Studio Code
# ----------------------------------------------------------------------
.vscode/

# JetBrains IDEs
.idea/

# Vim
*.swp
*.swo

# ----------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------
*.log

# ----------------------------------------------------------------------
# Temporary files
# ----------------------------------------------------------------------
*.tmp
*.temp

# ----------------------------------------------------------------------
# MATLAB generated binaries
# ----------------------------------------------------------------------
*.mex*

# ----------------------------------------------------------------------
# Ignore compressed archives
# ----------------------------------------------------------------------
*.zip
*.rar
*.7z

# ----------------------------------------------------------------------
# Ignore compiled libraries/executables
# ----------------------------------------------------------------------
*.exe
*.dll
*.so
*.dylib
*.o
*.obj